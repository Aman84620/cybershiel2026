# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# WhoisXML API (https://whoisxmlapi.com)
WHOIS_API_KEY=your_whois_api_key_here

# Email (Nodemailer) — use Gmail App Password or SMTP credentials
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
# OR use a single key for Gmail:
# EMAIL_KEY=your_gmail_app_password

# Firebase Service Account (paste full JSON as single line)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_CONFIG=
